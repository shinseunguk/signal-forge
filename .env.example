# ── App ─────────────────────────────────────────────
PORT=3000

# ── Database ────────────────────────────────────────
# Docker Compose 로 구동 시 host 는 컴포즈 서비스명(db).
# 로컬 PostgreSQL 로 직접 실행 시 host=localhost 로 변경.
DATABASE_URL=postgres://sf:sf@db:5432/signal_forge

# ── Market (시세 제공자) ────────────────────────────
# mock(기본) | toss(실 API, 스펙 확정 후)
MARKET_PROVIDER=mock

# ── Portfolio seed ──────────────────────────────────
PORTFOLIO_INITIAL_CASH=100000000
PORTFOLIO_NAME=signal-forge-main

# ── Risk gate (기획서 §6.3) ─────────────────────────
DAILY_LOSS_LIMIT_PCT=3
MAX_POSITION_WEIGHT_PCT=20

# ── 이후 Phase 에서 사용 (placeholder) ──────────────
TOSS_APP_KEY=
TOSS_APP_SECRET=
TOSS_API_BASE=https://openapi.tossinvest.com
LLM_API_KEY=
LLM_MODEL=
DART_API_KEY=
SLACK_WEBHOOK_URL=
