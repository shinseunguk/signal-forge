# ── App ─────────────────────────────────────────────
PORT=3000

# ── Database ────────────────────────────────────────
# Docker Compose 로 구동 시 host 는 컴포즈 서비스명(db).
# 로컬 PostgreSQL 로 직접 실행 시 host=localhost 로 변경.
DATABASE_URL=postgres://sf:sf@db:5432/signal_forge

# ── Market (시세 제공자) ────────────────────────────
# mock(기본) | toss(실 API, 스펙 확정 후)
MARKET_PROVIDER=mock

# ── Signals (LLM 태거) ──────────────────────────────
# mock(기본) | claude(실 API, 키·프롬프트 확정 후)
SIGNAL_TAGGER=mock

# ── Scheduler ───────────────────────────────────────
# false 면 cron 잡 본문을 건너뜀
SCHEDULER_ENABLED=true

# ── Portfolio seed ──────────────────────────────────
PORTFOLIO_NAME=signal-forge-main
# 계좌 기준 통화: USD(미국 주식 전용) | KRW
PORTFOLIO_BASE_CURRENCY=USD
# 펀딩: 1억 KRW 를 아래 환율로 USD 환전해 계좌 개설
PORTFOLIO_FUNDING_KRW=100000000
FUNDING_FX_RATE=1350
# (KRW 계좌를 쓸 경우의 초기 현금)
PORTFOLIO_INITIAL_CASH=100000000

# ── FX (환율) ───────────────────────────────────────
# mock(기본) | exchangerate(실 API, 확정 후)
FX_PROVIDER=mock

# ── Risk gate (기획서 §6.3) ─────────────────────────
DAILY_LOSS_LIMIT_PCT=3
MAX_POSITION_WEIGHT_PCT=20

# ── 이후 Phase 에서 사용 (placeholder) ──────────────
TOSS_APP_KEY=
TOSS_APP_SECRET=
TOSS_API_BASE=https://openapi.tossinvest.com
LLM_API_KEY=
LLM_MODEL=
DART_API_KEY=

# ── Notification (알림 채널) ────────────────────────
# discord(기본) | slack
NOTIFIER=discord
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
